# breadmin-conductor environment variables

# Required
ANTHROPIC_API_KEY=your-key-here

# Optional — defaults shown
CONDUCTOR_MODEL=claude-sonnet-4-6
CONDUCTOR_MAX_BUDGET=5.00          # USD per session
CONDUCTOR_MAX_TURNS=200            # max turns per claude -p invocation
CONDUCTOR_DATA_DIR=~/.local/share/conductor  # sessions/, cost.jsonl
